<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - XtremeType</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="@Url.Content("~/css/site.css?v=2")" />
    <link rel="stylesheet" href="@Url.Content("~/css/Responsive.css?v=2")" />
    <link rel="stylesheet" href="@Url.Content("~/lib/toastr/toastr.min.css")" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="apple-touch-icon" sizes="180x180" href="@Url.Content("~/images/apple-touch-icon.png")" />
    <link rel="icon" type="image/png" sizes="16x16" href="@Url.Content("~/images/favicon-16x16.png")" />
    <link rel="icon" type="image/png" sizes="32x32" href="@Url.Content("~/images/favicon-32x32.png")" />
    <link rel="icon" type="image/png" sizes="48x48" href="@Url.Content("~/images/favicon-48x48.png")" />
    <link rel="manifest" href="@Url.Content("~/lib/site/site.webmanifest")" />

</head>
<body>
    <div class="topbar-marquee">
        <div class="marquee-text">
            Free Shipping
        </div>
    </div>

    @{
        var topBarPhone = Context.Session.GetString("TopBarPhone");
    }

    @if (!string.IsNullOrWhiteSpace(topBarPhone))
    {
        <div class="top-bar">
            Have Questions? Need Help? Call Us Today!
            <a href="tel:@topBarPhone" style="color: inherit; text-decoration: none;">
                @topBarPhone
            </a>
        </div>
    }


    <header class="navbar">
        @await Html.PartialAsync("_Navbar")
    </header>

    <div class="progress-container">
        @await Html.PartialAsync("_Checkout")
    </div>

    <div class="container-fluid px-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @await Html.PartialAsync("_SearchPopup")

    <section class="reviews-section">
        <div class="container">
            <div class="banner-slider">
                <h2 id="bannerText">
                    OVER <span class="highlight">2,000,000</span> HAPPY CUSTOMERS
                </h2>
            </div>
        </div>
    </section>

    @await Html.PartialAsync("_Footer")
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/waypoints/4.0.1/jquery.waypoints.min.js"></script>
    <script src="@Url.Content("~/lib/toastr/toastr.min.js")"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="@Url.Content("~/js/site.js?v=2")"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
