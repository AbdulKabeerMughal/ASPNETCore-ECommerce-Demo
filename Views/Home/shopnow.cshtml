@{
    ViewData["Title"] = "Shop Now";
    Layout = "_Layout";
}

<style>
    .shop-products {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 25px;
        padding: 30px;
    }

    .product-card {
        border: 1px solid #eee;
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        text-align: center;
    }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        }

    .product-image {
        width: 100%;
        aspect-ratio: 1 / 1;    
        background: #f8f8f8;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .product-image img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain; 
        }
    .product-info {
        padding: 15px;
    }

        .product-info h3 {
            font-size: 18px;
            color: #222;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .product-info .price {
            color: #c41e3a;
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 5px;
        }

        .product-info .vehicle {
            font-size: 13px;
            color: #777;
            margin-bottom: 10px;
        }

    .add-to-cart-btn {
        background: #c41e3a;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.3s ease;
    }

        .add-to-cart-btn:hover {
            background: #a91831;
        }

    .pagination-wrapper {
        grid-column: 1 / -1;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        margin: 30px 0;
        gap: 10px;
        flex-wrap: wrap;
    }

    .page-btn {
        border: 1px solid #ddd;
        background: #fff;
        color: #333;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
        font-size: 14px;
        min-width: 40px;
        transition: all 0.3s ease;
    }

        .page-btn:hover:not(:disabled) {
            background: #c41e3a;
            color: #fff;
            border-color: #c41e3a;
        }

        .page-btn.active {
            background: #c41e3a;
            color: #fff;
            border-color: #c41e3a;
            font-weight: 600;
        }

        .page-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .page-info {
        color: #666;
        font-size: 14px;
        font-weight: 500;
    }

    .clear-btn {
        background-color: #c41e3a;
        color: #fff;
        border: none;
        padding: 7px 9px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        margin-left: 62px;
    }

        .clear-btn i {
            margin-right: 8px;
        }

        .clear-btn:hover {
            background-color: #a91c32; 
            box-shadow: 0 0 10px rgba(196, 30, 58, 0.4);
            transform: translateY(-1px);
        }

        .clear-btn:active {
            transform: scale(0.98);
        }

</style>

<div class="shop-page">
    <button class="filter-toggle" id="filterToggle" aria-label="Open Filters"></button>

    <aside class="filter-sidebar">
        <div class="accordion" id="filterAccordion">

            <div class="accordion-item">
                <h2 class="accordion-header" id="headingCategory">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCategory">
                        Product Family
                    </button>
                </h2>
                <div id="collapseCategory" class="accordion-collapse collapse show" data-bs-parent="#filterAccordion">
                    <div class="accordion-body" id="filterCategories"></div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header" id="headingYear">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseYear">
                        Year
                    </button>
                </h2>
                <div id="collapseYear" class="accordion-collapse collapse" data-bs-parent="#filterAccordion">
                    <div class="accordion-body" id="filterYear"></div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header" id="headingMake">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMake">
                        Make
                    </button>
                </h2>
                <div id="collapseMake" class="accordion-collapse collapse" data-bs-parent="#filterAccordion">
                    <div class="accordion-body" id="filterMake"></div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header" id="headingModel">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseModel">
                        Model
                    </button>
                </h2>
                <div id="collapseModel" class="accordion-collapse collapse" data-bs-parent="#filterAccordion">
                    <div class="accordion-body" id="filterModel"></div>
                </div>
            </div>

            @* <div class="accordion-item">
                <h2 class="accordion-header" id="headingBrand">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseBrand">
                        Brand
                    </button>
                </h2>
                <div id="collapseBrand" class="accordion-collapse collapse" data-bs-parent="#filterAccordion">
                    <div class="accordion-body" id="filterBrand"></div>
                </div>
            </div> *@

            

            <div class="text-center px-3">
                <button id="btnClearFilters" class="clear-btn">
                    <i class="fas fa-undo me-2"></i> Clear Selection
                </button>
            </div>

        </div>
    </aside>

    <section class="shop-products" id="productsContainer">
        <p>Loading products...</p>
    </section>
</div>

@section Scripts {
<script>
        var baseUrl = '@Url.Content("~/")';

        @using Microsoft.AspNetCore.Http
    @inject IHttpContextAccessor HttpContextAccessor
    var sessionCategory = '@(HttpContextAccessor.HttpContext.Session.GetString("SelectedCategory") ?? "")';

        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("btnClearFilters")?.addEventListener("click", function () {
                document.querySelectorAll('#filterAccordion input[type="checkbox"]').forEach(cb => cb.checked = false);
                localStorage.removeItem("selectedYear");
                localStorage.removeItem("selectedMake");
                localStorage.removeItem("selectedModel");
                localStorage.removeItem("selectedBrand");
                localStorage.removeItem("selectedCategory");

                if (typeof loadProducts === 'function') {
                    loadProducts();
                }
            });
        });
</script>

<script src="~/js/XtremeTypeScript/FrontendScript/shopnow.js"></script>
}