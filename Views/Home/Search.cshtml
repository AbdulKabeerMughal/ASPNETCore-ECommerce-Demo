@model XtremeType.ViewModels.SearchView

<div class="container py-4">
    <div class="breadcrumb mb-3">
        <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-dark">Home → </a>
        <span class="text-muted"> Your search for '<strong>@Model.Keyword</strong>'</span>
    </div>

    <h2 class="mb-4">Search Results</h2>

    @if (Model.Results != null && Model.Results.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model.Results)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <a href="@Url.Action("ProductDetail", "Home", new { id = product.Id })" class="text-decoration-none text-dark">
                            <img src="@product.ImageUrl" class="card-img-top product-img" alt="@product.ProductName" />
                            <div class="card-body">
                                <h5 class="card-title mb-3">@product.ProductName</h5>

                                <table class="table table-borderless table-sm mb-2">
                                    <tbody>
                                        <tr>
                                            <th class="text-muted">Make</th>
                                            <td>@product.VehicleMake</td>
                                        </tr>
                                        <tr>
                                            <th class="text-muted">Model</th>
                                            <td>@product.VehicleModel</td>
                                        </tr>
                                        <tr>
                                            <th class="text-muted">Year</th>
                                            <td>@product.VehicleYear</td>
                                        </tr>
                                        <tr>
                                            <th class="text-muted">Category</th>
                                            <td>@product.CategoryName</td>
                                        </tr>
                                    </tbody>
                                </table>

                                <p class="card-text fw-bold text-danger fs-5 mt-2 text-end">
                                    @product.Price?.ToString("C", new System.Globalization.CultureInfo("en-US"))
                                </p>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning mt-4">
            No products found for '<strong>@Model.Keyword</strong>'
        </div>
    }
</div>

<style>
    .card-body table th {
        width: 35%;
    }

    .card-body table td {
        width: 65%;
        font-weight: 500;
    }

    .card:hover {
        transform: translateY(-5px);
        transition: all 0.3s ease-in-out;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 600;
    }
    .product-img {
        width: 100%;
        height: 200px;
        object-fit: cover; 
        display: block;
        border-radius: 0.5rem;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>
